+export function calcVat(
+  taxableBase: number,
+  opts: { rate?: number; official?: boolean } = {},
+): number {
+  if (!opts.official) return 0
+  const rate = opts.rate ?? DEFAULT_VAT_RATE
+  if (taxableBase <= 0 || rate <= 0) return 0
+  return Math.floor((taxableBase * rate) / 100)
