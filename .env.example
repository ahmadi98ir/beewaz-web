# ─── کپی این فایل به .env و مقادیر واقعی را جایگزین کن ─────────────────────
# cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_this_strong_password_123

# ── Database URL (اجباری — بدون این container کرش میکند) ─────────────────────
# در Coolify: از طریق سرویس PostgreSQL این متغیر ست کن
# مثال: postgresql://postgres:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgresql://postgres:change_this_strong_password_123@db:5432/beewaz

# ── Next.js Auth ──────────────────────────────────────────────────────────────
# تولید: openssl rand -base64 32
AUTH_SECRET=replace_with_32_char_random_string_here

# ── URL سایت (در production آدرس واقعی دامنه) ────────────────────────────────
NEXT_PUBLIC_APP_URL=https://beewaz.ir
NEXTAUTH_URL=https://beewaz.ir

# ── ادمین ──────────────────────────────────────────────────────────────────────
ADMIN_PHONE=09120000000
ADMIN_NAME=مدیر سیستم
# توکن ورود به پنل ادمین (اجباری در production)
# تولید: openssl rand -hex 32
ADMIN_TOKEN=replace_with_strong_random_token

# ── درگاه پرداخت ──────────────────────────────────────────────────────────────
# زرین‌پال
ZARINPAL_MERCHANT_ID=your-zarinpal-merchant-id
ZARINPAL_SANDBOX=false
# آی‌دی‌پی
IDPAY_API_KEY=your-idpay-api-key
IDPAY_SANDBOX=false

# ── SMS.ir (پیامک) ───────────────────────────────────────────────────────────
SMS_IR_API_KEY=your_sms_ir_api_key
SMS_IR_LINE_NUMBER=10000047956

# ── Anthropic API (اختیاری - برای چت‌بات) ────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── تنظیمات قدیمی (سازگاری) ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=بیواز
