# ─── Database ─────────────────────────────────────────────────────────────────
# فرمت: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/beewaz"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# با دستور: openssl rand -base64 32 بسازید
AUTH_SECRET="replace-with-a-random-secret"

# ─── AI / Chatbot ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── Payment Gateway (ZarinPal) ──────────────────────────────────────────────
ZARINPAL_MERCHANT_ID=""
ZARINPAL_SANDBOX="true"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="بیواز"
NODE_ENV="development"
